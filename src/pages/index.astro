---
import '../styles/global.css';

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Personal homepage of Wenxuan Zhang." />
    <meta name="generator" content={Astro.generator} />
    <title>Wenxuan Zhang</title>
  </head>
  <body>
    <main>
      <header>
        <p class="eyebrow">Wenxuan Zhang</p>
        <h1>Software engineer building small, useful things.</h1>
        <p class="intro">
          I use this site as a quiet home on the internet: projects, notes, and links
          that are useful enough to keep around.
        </p>
      </header>

      <section aria-labelledby="projects">
        <h2 id="projects">Projects</h2>
        <ul>
          <li>
            <a href="https://github.com/zhangwenxuan322">GitHub</a>
            <span>Code, experiments, and unfinished ideas.</span>
          </li>
          <li>
            <a href="/">This site</a>
            <span>A minimal Astro homepage hosted on GitHub Pages.</span>
          </li>
        </ul>
      </section>

      <section aria-labelledby="notes">
        <h2 id="notes">Notes</h2>
        <p>
          No blog treadmill. Just short references and practical notes when something
          is worth remembering.
        </p>
      </section>

      <section aria-labelledby="contact">
        <h2 id="contact">Elsewhere</h2>
        <p>
          <a href="https://github.com/zhangwenxuan322">GitHub</a>
        </p>
      </section>
    </main>
  </body>
</html>
