---
import '../styles/global.css';

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Personal homepage of Oscar Zhang, a full stack software engineer in Canberra."
    />
    <meta name="generator" content={Astro.generator} />
    <title>Wenxuan (Oscar) Zhang</title>
  </head>
  <body>
    <main>
      <header>
        <p class="name">Wenxuan (Oscar) Zhang</p>
        <nav class="contact-links" aria-label="Contact links">
          <a href="mailto:oscarzhangwx@gmail.com">Email</a>
          <a href="https://github.com/zhangwenxuan322">GitHub</a>
          <a href="https://linkedin.com/in/wenxuan322">LinkedIn</a>
        </nav>
        <p class="intro">
          Full stack software engineer in Canberra. I work around web applications,
          cloud systems, data pipelines, and practical automation, with a preference
          for simple tools that make messy operational work easier.
        </p>
      </header>

      <section aria-labelledby="work">
        <h2 id="work">Work</h2>
        <ul>
          <li>
            <strong>Now</strong>
            <span>Analyst Programmer at <a href="https://evolvefm.com.au/">Evolve FM</a>, building internal tools, automations, data workflows, and reporting systems for facilities operations.</span>
          </li>
          <li>
            <strong>Before</strong>
            <span>Worked on AWS data engineering at <a href="https://shinesolutions.com/">Shine Solutions</a> and large-scale grid data systems with Spark, Flink, Kafka, and graph databases in China.</span>
          </li>
          <li>
            <strong>Also</strong>
            <span>Started with iOS and mobile app development, which still shapes how I think about user-facing software.</span>
          </li>
        </ul>
      </section>

      <section aria-labelledby="projects">
        <h2 id="projects">Selected</h2>
        <ul>
          <li>
            <strong>AI tools</strong>
            <span>Built healthcare and therapy prototypes using Django, Python, speech-to-text, LLMs, and AWS.</span>
          </li>
          <li>
            <strong>Data systems</strong>
            <span>Worked on pipelines and dashboards for infrastructure, energy, and operations data.</span>
          </li>
        </ul>
      </section>
    </main>
  </body>
</html>
