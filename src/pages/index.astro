<style>
  :root {
    color-scheme: light;
    --bg: #fbfaf7;
    --text: #151515;
    --muted: #62615d;
    --line: #dedbd2;
    --accent: #0b5fff;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
      "Courier New", monospace;
    background: var(--bg);
    color: var(--text);
  }

  body {
    margin: 0;
  }

  main {
    width: min(720px, calc(100vw - 40px));
    margin: 0 auto;
    padding: 72px 0 56px;
  }

  header,
  section {
    border-bottom: 1px solid var(--line);
    padding: 0 0 28px;
    margin: 0 0 28px;
  }

  section:last-child {
    border-bottom: 0;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .eyebrow,
  h2 {
    color: var(--muted);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    margin: 0 0 14px;
  }

  h1 {
    font-size: clamp(32px, 8vw, 64px);
    font-weight: 500;
    letter-spacing: -0.06em;
    line-height: 0.95;
    margin: 0 0 24px;
    max-width: 11ch;
  }

  .intro {
    font-size: 18px;
    max-width: 58ch;
  }

  p,
  li {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.65;
  }

  p {
    margin: 0;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 16px;
    padding: 10px 0;
  }

  a {
    color: var(--text);
    text-decoration-color: var(--line);
    text-underline-offset: 4px;
  }

  a:hover,
  a:focus-visible {
    color: var(--accent);
    text-decoration-color: currentColor;
  }

  a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  @media (max-width: 560px) {
    main {
      width: min(100% - 28px, 720px);
      padding-top: 44px;
    }

    li {
      grid-template-columns: 1fr;
      gap: 2px;
    }
  }
</style>
